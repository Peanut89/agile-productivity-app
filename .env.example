# Supabase credentials for cloud sync.
# Copy this file to ".env" and fill in your project's values
# (Supabase Dashboard → Project Settings → API). Both are safe to expose
# in a client app; row-level security protects the data.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
